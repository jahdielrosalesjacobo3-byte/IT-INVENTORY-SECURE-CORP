<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Registrar administrador — SECURE CORP</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/css/theme.css" />
  </head>
  <body>
    <%- include('partials/navbar') %>

    <main class="container py-4 mb-5">
      <div class="row justify-content-center">
        <div class="col-md-5">
          <% if (messages && messages.success && messages.success.length) { %>
            <div class="alert alert-success"><% messages.success.forEach(function(m) { %><div><%= m %></div><% }) %></div>
          <% } %>
          <% if (messages && messages.error && messages.error.length) { %>
            <div class="alert alert-danger"><% messages.error.forEach(function(m) { %><div><%= m %></div><% }) %></div>
          <% } %>

          <div class="card sc-card border-0">
            <div class="card-body p-4 p-md-5">
              <h2 class="sc-page-title mb-2">Nuevo acceso</h2>
              <p class="sc-page-subtitle mb-4">Crear perfil administrativo para el inventario IT. SECURE CORP.</p>

              <form method="post" action="/registrar-admin">
                <div class="mb-3">
                  <label class="form-label">Nombre de usuario</label>
                  <input type="text" name="username" class="form-control sc-input <%= (fieldErrors && fieldErrors.username) ? 'is-invalid' : '' %>" value="<%= (old && old.username) ? old.username : '' %>" required />
                  <% if (fieldErrors && fieldErrors.username) { %><div class="invalid-feedback"><%= fieldErrors.username[0] %></div><% } %>
                </div>
                <div class="mb-3">
                  <label class="form-label">Correo electrónico</label>
                  <input type="email" name="email" class="form-control sc-input <%= (fieldErrors && fieldErrors.email) ? 'is-invalid' : '' %>" value="<%= (old && old.email) ? old.email : '' %>" required />
                  <% if (fieldErrors && fieldErrors.email) { %><div class="invalid-feedback"><%= fieldErrors.email[0] %></div><% } %>
                </div>
                <div class="mb-3">
                  <label class="form-label">Nombre de visualización</label>
                  <input type="text" name="first_name" class="form-control sc-input <%= (fieldErrors && fieldErrors.first_name) ? 'is-invalid' : '' %>" value="<%= (old && old.first_name) ? old.first_name : '' %>" required />
                  <% if (fieldErrors && fieldErrors.first_name) { %><div class="invalid-feedback"><%= fieldErrors.first_name[0] %></div><% } %>
                </div>
                <div class="mb-3">
                  <label class="form-label">Contraseña</label>
                  <input type="password" name="password1" class="form-control sc-input <%= (fieldErrors && fieldErrors.password1) ? 'is-invalid' : '' %>" required />
                  <div class="form-text">Mínimo 8 caracteres. Se recomienda letras, números y símbolos.</div>
                  <% if (fieldErrors && fieldErrors.password1) { %><div class="invalid-feedback"><%= fieldErrors.password1[0] %></div><% } %>
                </div>
                <div class="mb-4">
                  <label class="form-label">Confirmar contraseña</label>
                  <input type="password" name="password2" class="form-control sc-input <%= (fieldErrors && fieldErrors.password2) ? 'is-invalid' : '' %>" required />
                  <% if (fieldErrors && fieldErrors.password2) { %><div class="invalid-feedback"><%= fieldErrors.password2[0] %></div><% } %>
                </div>

                <div class="d-grid gap-2">
                  <button type="submit" class="btn sc-btn-primary">Finalizar registro</button>
                  <a href="/home" class="btn btn-link text-muted p-0">Regresar al dashboard</a>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </main>

    <footer class="sc-footer-brand"><strong>SECURE <span>CORP</span></strong> — Inventario IT</footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
