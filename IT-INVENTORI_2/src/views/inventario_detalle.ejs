<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %> — SECURE CORP</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/css/theme.css" />
  </head>
  <body>
    <%- include('partials/navbar') %>

    <main class="container mb-5">
      <% if (messages && messages.success && messages.success.length) { %>
        <div class="alert alert-success"><% messages.success.forEach(function(m) { %><div><%= m %></div><% }) %></div>
      <% } %>
      <% if (messages && messages.error && messages.error.length) { %>
        <div class="alert alert-danger"><% messages.error.forEach(function(m) { %><div><%= m %></div><% }) %></div>
      <% } %>

      <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <div>
          <h1 class="sc-page-title"><%= title %></h1>
          <p class="sc-page-subtitle mb-0">Listado del inventario. SECURE CORP.</p>
        </div>
        <a href="/registrar/<%= tipo %>" class="btn sc-btn-primary">+ Agregar <%= tipo === 'computadora' ? 'computadora' : tipo === 'celular' ? 'celular' : 'SIM' %></a>
      </div>

      <div class="card sc-card">
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-sm align-middle sc-table mb-0">
              <thead>
                <tr>
                  <th>#</th>
                  <th>Detalles</th>
                  <th>Identificador</th>
                  <th>Asignación</th>
                  <th class="text-end" style="width: 140px;">Acciones</th>
                </tr>
              </thead>
              <tbody>
                <% if (!objetos.length) { %>
                  <tr><td colspan="5" class="text-center text-muted py-4">No hay registros en este inventario.</td></tr>
                <% } %>
                <% objetos.forEach(function(obj, index) {
                  const empleado = obj.asignado_a_id ? empleadosPorId[obj.asignado_a_id] : null;
                %>
                  <tr>
                    <td><%= index + 1 %></td>
                    <td>
                      <% if (tipo === "computadora" || tipo === "celular") { %><strong><%= obj.marca %> <%= obj.modelo %></strong>
                      <% } else { %><strong>Tel: <%= obj.numero_celular %></strong><% } %>
                    </td>
                    <td>
                      <% if (tipo === "computadora" || tipo === "celular") { %>
                        <span class="badge bg-secondary">S/N: <%= obj.serie %></span>
                      <% } else { %>
                        <span class="badge bg-secondary"><%= (obj.tipo === 'ESIM') ? 'eSIM' : 'SIM' %></span>
                        <span class="badge bg-secondary ms-1">ICC: <%= obj.icc %></span>
                        <span class="badge bg-light text-dark border ms-1">IMSI: <%= obj.imei %></span>
                        <% if (obj.es_reemplazo) { %>
                          <span class="badge bg-warning text-dark ms-1">Reemplazo</span>
                        <% } %>
                        <% if (obj.tipo === 'ESIM' && obj.qr_esim) { %>
                          <a class="badge bg-info text-white ms-1 text-decoration-none" href="<%= obj.qr_esim %>" target="_blank" rel="noreferrer">Ver QR</a>
                        <% } %>
                      <% } %>
                    </td>
                    <td>
                      <% if (!empleado) { %><span class="badge bg-success">Disponible</span>
                      <% } else { %>
                        <div><span class="badge bg-primary"><%= empleado.nombre %> <%= empleado.apellidos %></span><small class="text-muted d-block">Ticket: <%= empleado.ticket %></small></div>
                      <% } %>
                    </td>
                    <td class="text-end">
                      <a href="/inventario/<%= tipo %>/<%= obj.id %>/editar" class="btn btn-sm sc-btn-edit py-1 px-2">Editar</a>
                      <form action="/inventario/<%= tipo %>/<%= obj.id %>/eliminar" method="post" class="d-inline ms-1" onsubmit="return confirm('¿Eliminar este equipo del inventario?');">
                        <button type="submit" class="btn btn-sm btn-danger py-1 px-2">Eliminar</button>
                      </form>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </main>

    <footer class="sc-footer-brand"><strong>SECURE <span>CORP</span></strong> — Inventario IT</footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
