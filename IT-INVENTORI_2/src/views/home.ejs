<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dashboard — SECURE CORP</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/css/theme.css" />
  </head>
  <body>
    <%- include('partials/navbar') %>

    <main class="container mb-5">
      <% if (messages && messages.success && messages.success.length) { %>
        <div class="alert alert-success"><% messages.success.forEach(function(m) { %><div><%= m %></div><% }) %></div>
      <% } %>
      <% if (messages && messages.error && messages.error.length) { %>
        <div class="alert alert-danger"><% messages.error.forEach(function(m) { %><div><%= m %></div><% }) %></div>
      <% } %>

      <div class="row mb-4">
        <div class="col">
          <h1 class="sc-page-title">Resumen de inventario</h1>
          <p class="sc-page-subtitle">Disponibilidad actual de equipos IT. SECURE CORP.</p>
        </div>
      </div>

      <div class="row g-3">
        <div class="col-md-4">
          <div class="card sc-card">
            <div class="card-body">
              <h5 class="card-title">Computadoras</h5>
              <p class="card-text mb-1">Totales: <strong><%= data.comp_total %></strong></p>
              <p class="card-text mb-3">Libres: <strong><%= data.comp_libres %></strong></p>
              <div class="progress" role="progressbar" aria-valuemin="0" aria-valuemax="100">
                <div class="progress-bar" style="width: <%= data.p_compus %>%"><%= data.p_compus %>%</div>
              </div>
              <a href="/inventario/computadora" class="btn btn-link btn-sm mt-2 p-0 text-decoration-none me-2" style="color: var(--sc-blue);">Ver detalle</a>
              <a href="/registrar/computadora" class="btn btn-link btn-sm mt-2 p-0 text-decoration-none" style="color: var(--sc-blue);">+ Agregar</a>
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card sc-card">
            <div class="card-body">
              <h5 class="card-title">Celulares</h5>
              <p class="card-text mb-1">Totales: <strong><%= data.cel_total %></strong></p>
              <p class="card-text mb-3">Libres: <strong><%= data.cel_libres %></strong></p>
              <div class="progress" role="progressbar" aria-valuemin="0" aria-valuemax="100">
                <div class="progress-bar" style="width: <%= data.p_cel %>%"><%= data.p_cel %>%</div>
              </div>
              <a href="/inventario/celular" class="btn btn-link btn-sm mt-2 p-0 text-decoration-none me-2" style="color: var(--sc-blue);">Ver detalle</a>
              <a href="/registrar/celular" class="btn btn-link btn-sm mt-2 p-0 text-decoration-none" style="color: var(--sc-blue);">+ Agregar</a>
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card sc-card">
            <div class="card-body">
              <h5 class="card-title">SIM Cards</h5>
              <p class="card-text mb-1">Totales: <strong><%= data.sim_total %></strong></p>
              <p class="card-text mb-3">Libres: <strong><%= data.sim_libres %></strong></p>
              <div class="progress" role="progressbar" aria-valuemin="0" aria-valuemax="100">
                <div class="progress-bar" style="width: <%= data.p_sim %>%"><%= data.p_sim %>%</div>
              </div>
              <a href="/inventario/sim" class="btn btn-link btn-sm mt-2 p-0 text-decoration-none me-2" style="color: var(--sc-blue);">Ver detalle</a>
              <a href="/registrar/sim" class="btn btn-link btn-sm mt-2 p-0 text-decoration-none" style="color: var(--sc-blue);">+ Agregar</a>
            </div>
          </div>
        </div>
      </div>

      <div class="row mt-4">
        <div class="col-md-6"><a href="/personal" class="btn sc-btn-outline w-100">Ver listado de personal</a></div>
        <div class="col-md-6"><a href="/asignar" class="btn sc-btn-primary w-100">Nueva asignación</a></div>
      </div>
    </main>

    <footer class="sc-footer-brand"><strong>SECURE <span>CORP</span></strong> — Inventario IT</footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
