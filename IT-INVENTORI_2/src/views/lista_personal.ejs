<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Personal — SECURE CORP</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/css/theme.css" />
  </head>
  <body>
    <%- include('partials/navbar') %>

    <main class="container mb-5">
      <% if (messages && messages.success && messages.success.length) { %>
        <div class="alert alert-success"><% messages.success.forEach(function(m) { %><div><%= m %></div><% }) %></div>
      <% } %>
      <% if (messages && messages.error && messages.error.length) { %>
        <div class="alert alert-danger"><% messages.error.forEach(function(m) { %><div><%= m %></div><% }) %></div>
      <% } %>

      <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <div>
          <h1 class="sc-page-title">Personal y equipos asignados</h1>
          <p class="sc-page-subtitle mb-0">Colaboradores y activos IT asociados. SECURE CORP.</p>
        </div>
        <a href="/asignar" class="btn sc-btn-primary">+ Nueva entrega</a>
      </div>

      <form class="row g-2 mb-3" method="get" action="/personal">
        <div class="col-md-4">
          <input type="text" class="form-control sc-input" name="q" placeholder="Buscar por nombre, apellidos o ticket" value="<%= q || '' %>" />
        </div>
        <div class="col-md-2">
          <button class="btn sc-btn-outline w-100" type="submit">Buscar</button>
        </div>
      </form>

      <div class="card sc-card">
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-sm align-middle sc-table mb-0">
              <thead>
                <tr>
                  <th>Colaborador</th>
                  <th>Computadoras</th>
                  <th>Celulares</th>
                  <th>SIM Cards</th>
                  <th class="text-end" style="width: 140px;">Acciones</th>
                </tr>
              </thead>
              <tbody>
                <% if (!items.length) { %>
                  <tr><td colspan="5" class="text-center text-muted py-4">No se encontraron colaboradores con los filtros actuales.</td></tr>
                <% } %>
                <% items.forEach(function(item) { %>
                  <tr>
                    <td>
                      <strong><%= item.empleado.nombre %> <%= item.empleado.apellidos %></strong>
                      <div class="text-muted small">Ticket: <%= item.empleado.ticket %> | <%= item.empleado.correo %></div>
                    </td>
                    <td>
                      <% if (!item.computadoras.length) { %><span class="text-muted small">Sin equipos</span><% } %>
                      <% item.computadoras.forEach(function(c) { %><div><span class="badge bg-secondary"><%= c.marca %> <%= c.modelo %> (S/N: <%= c.serie %>)</span></div><% }) %>
                    </td>
                    <td>
                      <% if (!item.celulares.length) { %><span class="text-muted small">Sin equipos</span><% } %>
                      <% item.celulares.forEach(function(c) { %><div><span class="badge bg-secondary"><%= c.marca %> <%= c.modelo %> (S/N: <%= c.serie %>)</span></div><% }) %>
                    </td>
                    <td>
                      <% if (!item.simcards.length) { %><span class="text-muted small">Sin SIMs</span><% } %>
                      <% item.simcards.forEach(function(s) { %><div><span class="badge bg-secondary">Tel: <%= s.numero_celular %> (ICC: <%= s.icc %>)</span></div><% }) %>
                    </td>
                    <td class="text-end">
                      <a href="/documento/empleado/<%= item.empleado.id %>" class="btn btn-sm btn-success py-1 px-2 text-white text-decoration-none" title="Descargar formato según equipo asignado">Documento</a>
                      <a href="/personal/<%= item.empleado.id %>/editar" class="btn btn-sm sc-btn-outline py-1 px-2">Editar</a>
                      <form action="/personal/<%= item.empleado.id %>/eliminar" method="post" class="d-inline ms-1" onsubmit="return confirm('¿Eliminar este colaborador y liberar sus equipos?');">
                        <button type="submit" class="btn btn-sm btn-danger py-1 px-2">Eliminar</button>
                      </form>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </main>

    <footer class="sc-footer-brand"><strong>SECURE <span>CORP</span></strong> — Inventario IT</footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
