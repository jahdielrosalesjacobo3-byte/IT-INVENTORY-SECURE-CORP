<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Iniciar sesión — SECURE CORP</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/css/theme.css" />
  </head>
  <body>
    <main class="sc-auth-wrap">
      <div class="sc-auth-card sc-animate">
        <div class="sc-auth-logo">
          <img src="/img/logoSC.png" alt="SECURE CORP" class="sc-logo mb-2" />
        </div>
        <p class="sc-auth-title text-center">Acceso al sistema</p>
        <p class="sc-auth-subtitle text-center">Inventario IT</p>

        <% if (messages && messages.success && messages.success.length) { %>
          <div class="alert alert-success">
            <% messages.success.forEach(function(m) { %><div><%= m %></div><% }) %>
          </div>
        <% } %>
        <% if (messages && messages.error && messages.error.length) { %>
          <div class="alert alert-danger">
            <% messages.error.forEach(function(m) { %><div><%= m %></div><% }) %>
          </div>
        <% } %>

        <form method="post" action="/login">
          <div class="mb-3">
            <label for="username" class="form-label">Usuario o correo</label>
            <input type="text" class="form-control sc-input <%= (fieldErrors && fieldErrors.username) ? 'is-invalid' : '' %>" id="username" name="username" value="<%= (old && old.username) ? old.username : '' %>" required />
            <% if (fieldErrors && fieldErrors.username) { %><div class="invalid-feedback"><%= fieldErrors.username[0] %></div><% } %>
          </div>
          <div class="mb-3">
            <label for="password" class="form-label">Contraseña</label>
            <input type="password" class="form-control sc-input <%= (fieldErrors && fieldErrors.password) ? 'is-invalid' : '' %>" id="password" name="password" required />
            <% if (fieldErrors && fieldErrors.password) { %><div class="invalid-feedback"><%= fieldErrors.password[0] %></div><% } %>
          </div>
          <button type="submit" class="btn sc-btn-primary w-100">Iniciar sesión</button>
        </form>
      </div>
    </main>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
