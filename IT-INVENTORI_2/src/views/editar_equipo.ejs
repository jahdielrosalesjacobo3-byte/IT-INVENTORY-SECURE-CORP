<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= titulo %> — SECURE CORP</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/css/theme.css" />
  </head>
  <body>
    <%- include('partials/navbar') %>

    <main class="container py-4 mb-5">
      <div class="row justify-content-center">
        <div class="col-md-6">
          <% if (messages && messages.error && messages.error.length) { %>
            <div class="alert alert-danger"><% messages.error.forEach(function(m) { %><div><%= m %></div><% }) %></div>
          <% } %>

          <div class="card sc-card border-0">
            <div class="card-body p-4 p-md-5">
              <h2 class="sc-page-title mb-2"><%= titulo %></h2>
              <p class="sc-page-subtitle mb-4">Modificar datos en inventario. SECURE CORP.</p>

              <form method="post" action="/inventario/<%= tipo %>/<%= item.id %>/editar">
                <% if (tipo === "computadora") { %>
                  <div class="mb-3">
                    <label class="form-label">Marca</label>
                    <input type="text" name="marca" class="form-control sc-input <%= (fieldErrors && fieldErrors.marca) ? 'is-invalid' : '' %>" value="<%= (old && old.marca) != null ? old.marca : item.marca %>" required />
                    <% if (fieldErrors && fieldErrors.marca) { %><div class="invalid-feedback"><%= fieldErrors.marca[0] %></div><% } %>
                  </div>
                  <div class="mb-3">
                    <label class="form-label">Modelo</label>
                    <input type="text" name="modelo" class="form-control sc-input <%= (fieldErrors && fieldErrors.modelo) ? 'is-invalid' : '' %>" value="<%= (old && old.modelo) != null ? old.modelo : item.modelo %>" required />
                    <% if (fieldErrors && fieldErrors.modelo) { %><div class="invalid-feedback"><%= fieldErrors.modelo[0] %></div><% } %>
                  </div>
                  <div class="mb-3">
                    <label class="form-label">Serie</label>
                    <input type="text" name="serie" class="form-control sc-input <%= (fieldErrors && fieldErrors.serie) ? 'is-invalid' : '' %>" value="<%= (old && old.serie) != null ? old.serie : item.serie %>" required />
                    <% if (fieldErrors && fieldErrors.serie) { %><div class="invalid-feedback"><%= fieldErrors.serie[0] %></div><% } %>
                  </div>
                  <div class="mb-4">
                    <label class="form-label">Estado</label>
                    <select name="estado" class="form-select sc-input">
                      <option value="Nuevo" <%= ((old && old.estado) || item.estado) === 'Nuevo' ? 'selected' : '' %>>Nuevo</option>
                      <option value="Usado" <%= ((old && old.estado) || item.estado) === 'Usado' ? 'selected' : '' %>>Usado</option>
                    </select>
                  </div>
                <% } else if (tipo === "celular") { %>
                  <div class="mb-3">
                    <label class="form-label">Marca</label>
                    <input type="text" name="marca" class="form-control sc-input <%= (fieldErrors && fieldErrors.marca) ? 'is-invalid' : '' %>" value="<%= (old && old.marca) != null ? old.marca : item.marca %>" required />
                    <% if (fieldErrors && fieldErrors.marca) { %><div class="invalid-feedback"><%= fieldErrors.marca[0] %></div><% } %>
                  </div>
                  <div class="mb-3">
                    <label class="form-label">Modelo</label>
                    <input type="text" name="modelo" class="form-control sc-input <%= (fieldErrors && fieldErrors.modelo) ? 'is-invalid' : '' %>" value="<%= (old && old.modelo) != null ? old.modelo : item.modelo %>" required />
                    <% if (fieldErrors && fieldErrors.modelo) { %><div class="invalid-feedback"><%= fieldErrors.modelo[0] %></div><% } %>
                  </div>
                  <div class="mb-4">
                    <label class="form-label">Serie</label>
                    <input type="text" name="serie" class="form-control sc-input <%= (fieldErrors && fieldErrors.serie) ? 'is-invalid' : '' %>" value="<%= (old && old.serie) != null ? old.serie : item.serie %>" required />
                    <% if (fieldErrors && fieldErrors.serie) { %><div class="invalid-feedback"><%= fieldErrors.serie[0] %></div><% } %>
                  </div>
                <% } else if (tipo === "sim") { %>
                  <div class="mb-3">
                    <label class="form-label">Número celular</label>
                    <input type="text" name="numero_celular" class="form-control sc-input <%= (fieldErrors && fieldErrors.numero_celular) ? 'is-invalid' : '' %>" value="<%= (old && old.numero_celular) != null ? old.numero_celular : item.numero_celular %>" required />
                    <% if (fieldErrors && fieldErrors.numero_celular) { %><div class="invalid-feedback"><%= fieldErrors.numero_celular[0] %></div><% } %>
                  </div>
                  <div class="mb-3">
                    <label class="form-label">ICC</label>
                    <input type="text" name="icc" class="form-control sc-input <%= (fieldErrors && fieldErrors.icc) ? 'is-invalid' : '' %>" value="<%= (old && old.icc) != null ? old.icc : item.icc %>" required />
                    <% if (fieldErrors && fieldErrors.icc) { %><div class="invalid-feedback"><%= fieldErrors.icc[0] %></div><% } %>
                  </div>
                  <div class="mb-4">
                    <label class="form-label">IMEI</label>
                    <input type="text" name="imei" class="form-control sc-input <%= (fieldErrors && fieldErrors.imei) ? 'is-invalid' : '' %>" value="<%= (old && old.imei) != null ? old.imei : item.imei %>" required />
                    <% if (fieldErrors && fieldErrors.imei) { %><div class="invalid-feedback"><%= fieldErrors.imei[0] %></div><% } %>
                  </div>
                <% } %>

                <div class="d-grid gap-2">
                  <button type="submit" class="btn sc-btn-primary">Guardar cambios</button>
                  <a href="/inventario/<%= tipo %>" class="btn sc-btn-outline">Cancelar</a>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </main>

    <footer class="sc-footer-brand"><strong>SECURE <span>CORP</span></strong> — Inventario IT</footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
