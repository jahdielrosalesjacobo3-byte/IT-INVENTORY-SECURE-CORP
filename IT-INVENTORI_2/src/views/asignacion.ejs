<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Nueva asignación — SECURE CORP</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/css/theme.css" />
  </head>
  <body>
    <%- include('partials/navbar') %>

    <main class="container py-4 mb-5">
      <div class="row justify-content-center">
        <div class="col-lg-9">
          <% if (messages && messages.error && messages.error.length) { %>
            <div class="alert alert-danger"><% messages.error.forEach(function(m) { %><div><%= m %></div><% }) %></div>
          <% } %>

          <div class="card sc-card border-0">
            <div class="card-body p-4 p-md-5">
              <h2 class="sc-page-title mb-2">Nueva asignación</h2>
              <p class="sc-page-subtitle mb-4">Vincular colaborador con equipos disponibles. SECURE CORP.</p>

              <form method="post" action="/asignar">
                <div class="mb-5">
                  <p class="text-uppercase text-muted small fw-bold mb-3">Datos del colaborador</p>
                  <div class="row g-3">
                    <div class="col-md-6">
                      <label class="form-label">Nombres</label>
                      <input type="text" name="nombre" class="form-control sc-input <%= (fieldErrors && fieldErrors.nombre) ? 'is-invalid' : '' %>" value="<%= (old && old.nombre) ? old.nombre : '' %>" required />
                      <% if (fieldErrors && fieldErrors.nombre) { %><div class="invalid-feedback"><%= fieldErrors.nombre[0] %></div><% } %>
                    </div>
                    <div class="col-md-6">
                      <label class="form-label">Apellidos</label>
                      <input type="text" name="apellidos" class="form-control sc-input <%= (fieldErrors && fieldErrors.apellidos) ? 'is-invalid' : '' %>" value="<%= (old && old.apellidos) ? old.apellidos : '' %>" required />
                      <% if (fieldErrors && fieldErrors.apellidos) { %><div class="invalid-feedback"><%= fieldErrors.apellidos[0] %></div><% } %>
                    </div>
                    <div class="col-md-6">
                      <label class="form-label">Correo corporativo</label>
                      <input type="email" name="correo" class="form-control sc-input <%= (fieldErrors && fieldErrors.correo) ? 'is-invalid' : '' %>" value="<%= (old && old.correo) ? old.correo : '' %>" required />
                      <% if (fieldErrors && fieldErrors.correo) { %><div class="invalid-feedback"><%= fieldErrors.correo[0] %></div><% } %>
                    </div>
                    <div class="col-md-3">
                      <label class="form-label">Cargo / puesto</label>
                      <input type="text" name="puesto" class="form-control sc-input <%= (fieldErrors && fieldErrors.puesto) ? 'is-invalid' : '' %>" value="<%= (old && old.puesto) ? old.puesto : '' %>" required />
                      <% if (fieldErrors && fieldErrors.puesto) { %><div class="invalid-feedback"><%= fieldErrors.puesto[0] %></div><% } %>
                    </div>
                    <div class="col-md-3">
                      <label class="form-label">No. ticket</label>
                      <input type="text" name="ticket" class="form-control sc-input <%= (fieldErrors && fieldErrors.ticket) ? 'is-invalid' : '' %>" value="<%= (old && old.ticket) ? old.ticket : '' %>" required />
                      <% if (fieldErrors && fieldErrors.ticket) { %><div class="invalid-feedback"><%= fieldErrors.ticket[0] %></div><% } %>
                    </div>
                  </div>
                </div>

                <div class="mb-5">
                  <p class="text-uppercase text-muted small fw-bold mb-3">Vincular activos disponibles</p>
                  <div class="row g-3">
                    <div class="col-md-4">
                      <label class="form-label">Computadora</label>
                      <select name="computadora_id" class="form-select sc-input">
                        <option value="">— Ninguna —</option>
                        <% computadoras.forEach(function(c) { %>
                          <option value="<%= c.id %>" <%= (old && old.computadora_id == c.id) ? 'selected' : '' %>><%= c.marca %> <%= c.modelo %> (S/N: <%= c.serie %>)</option>
                        <% }) %>
                      </select>
                    </div>
                    <div class="col-md-4">
                      <label class="form-label">Celular</label>
                      <select name="celular_id" class="form-select sc-input">
                        <option value="">— Ninguno —</option>
                        <% celulares.forEach(function(c) { %>
                          <option value="<%= c.id %>" <%= (old && old.celular_id == c.id) ? 'selected' : '' %>><%= c.marca %> <%= c.modelo %> (S/N: <%= c.serie %>)</option>
                        <% }) %>
                      </select>
                    </div>
                    <div class="col-md-4">
                      <label class="form-label">SIM Card</label>
                      <select name="sim_id" class="form-select sc-input">
                        <option value="">— Ninguna —</option>
                        <% simcards.forEach(function(s) { %>
                          <option value="<%= s.id %>" <%= (old && old.sim_id == s.id) ? 'selected' : '' %>>Tel: <%= s.numero_celular %> (ICC: <%= s.icc %>)</option>
                        <% }) %>
                      </select>
                    </div>
                  </div>
                  <p class="form-text text-muted mt-2">Solo se muestran equipos no asignados.</p>
                </div>

                <div class="d-flex justify-content-end gap-2">
                  <a href="/home" class="btn sc-btn-outline px-4">Cancelar</a>
                  <button type="submit" class="btn sc-btn-primary px-5">Confirmar asignación</button>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </main>

    <footer class="sc-footer-brand"><strong>SECURE <span>CORP</span></strong> — Inventario IT</footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
